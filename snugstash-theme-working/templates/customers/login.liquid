<div class="section"><div class="container" style="max-width:400px"><h1 style="text-align:center;margin-bottom:1.5rem">Log in</h1>{% form 'customer_login' %}{{ form.errors | default_errors }}<label class="vlabel">Email</label><input type="email" name="customer[email]" style="width:100%;padding:.7rem 1rem;border:1.5px solid #E2E8F0;border-radius:8px;margin-bottom:1rem"><label class="vlabel">Password</label><input type="password" name="customer[password]" style="width:100%;padding:.7rem 1rem;border:1.5px solid #E2E8F0;border-radius:8px;margin-bottom:1.25rem"><button type="submit" class="btn btn-primary btn-full">Log in</button>{% endform %}</div></div>
